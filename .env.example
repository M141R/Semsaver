# Flask
SECRET_KEY=replace-with-a-long-random-secret
FLASK_ENV=production
FLASK_DEBUG=0
SITE_URL=https://yourdomain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-server-secret-key-sb_secret_xxx
# Use your Publishable key here (Supabase docs call this the modern replacement for legacy anon key)
SUPABASE_ANON_KEY=your-publishable-key-sb_publishable_xxx
# OAuth providers (Google, etc.) are configured in Supabase Dashboard -> Authentication -> Providers
# Callback URL there should be: https://<your-project-ref>.supabase.co/auth/v1/callback

# Cloudflare Turnstile (widget key used by this Flask app login form)
TURNSTILE_SITE_KEY=your-turnstile-site-key
# Turnstile secret key should be configured in Supabase Dashboard Auth settings (not in this app .env)

# Azure Blob Storage (private container recommended)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
# Optional legacy compatibility variable. Not needed if AZURE_STORAGE_ACCOUNT_KEY is set.
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=resources

# Optional runtime port
PORT=5000

# Public upload moderation
PUBLIC_UPLOAD_MAX_MB=10
